# ───────────────────────────────────────────────────────────
# MQ Navigation – Flutter .env
# Used with: flutter run --dart-define-from-file=.env
#
# NOTE: In debug mode, a bare `flutter run` works without
#       this file because env_config.dart has hardcoded
#       development defaults.
# ───────────────────────────────────────────────────────────

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
GOOGLE_MAPS_API_KEY=your-maps-key
APP_ENV=development
