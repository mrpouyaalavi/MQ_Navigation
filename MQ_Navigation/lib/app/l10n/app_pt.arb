  "privacy_s2_title": "Quais informações pessoais coletamos",
  "privacy_s2_a_title": "A) Dados de conta e identidade",
  "privacy_s2_a_li1": "Nome completo (ou nome de exibição)",
  "privacy_s2_a_li2": "Endereço de e-mail",
