  "terms_s6_title": "गोपनीयता",
  "terms_s6_p1": "{appName} को तपाईंको प्रयोग हाम्रो गोपनीयता नीतिद्वारा पनि शासित छ।",
  "terms_s7_title": "वारेन्टी अस्वीकरण",
