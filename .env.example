# ───────────────────────────────────────────────────────────
# MQ Navigation – Flutter .env
# Used with: flutter run --dart-define-from-file=.env
#
# NOTE: In debug mode, a bare `flutter run` works without
#       this file because env_config.dart has hardcoded
#       development defaults.
# ───────────────────────────────────────────────────────────

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
GOOGLE_MAPS_API_KEY=your-maps-key
GOOGLE_ROUTES_API_KEY=your-server-google-routes-key
TFNSW_API_KEY=your-tfnsw-open-data-key
TFNSW_STOP_ID=10101403
ALLOWED_WEB_ORIGINS=http://localhost:3000,https://your-web-domain.com
APP_ENV=development
